#
# Copy this file to `.env` and update values.
#

# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=alumni_db
DB_USER=root
DB_PASSWORD=change_me

# JWT auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_MINUTES=1440

# App behavior
AUTO_INIT=1

# Allowed CORS origins (comma-separated). Use `*` to allow all.
CORS_ORIGINS=*

